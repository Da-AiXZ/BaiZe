sequenceDiagram
    autonumber
    participant App as BaizeApp
    participant PFS as PlatformFileSystem
    participant FM as FileManagerStrategy
    participant PS as PosixSpawnStrategy
    participant IOS as IosSystemStrategy
    participant FSS as FileSystemService
    participant Git as GitService
    participant Shell as GitShellService
    participant Process as Process
    participant PE as PermissionEngine
    participant TR as ToolRegistry
    participant PMS as PlanModeState
    participant Loop as AgentLoop
    participant AT as AgentTool
    participant Sub as AgentLoop(sub)
    participant ME as MemoryExtractor
    participant MS as MemoryStore

    %% App startup: filesystem probe
    App->>PFS: init(probePath: projectRoot)
    PFS->>FM: createDirectory(probePath)
    alt FileManager success
        PFS->>PFS: selectedStrategy = .fileManager
    else FileManager fails
        PFS->>PS: createDirectory(probePath)
        alt posix_spawn success
            PFS->>PFS: selectedStrategy = .posixSpawn
        else posix_spawn fails
            PFS->>IOS: createDirectory(probePath)
            PFS->>PFS: selectedStrategy = .iosSystem
        end
    end
    PFS-->>App: selectedStrategy

    %% UI / AI shared filesystem path
    App->>FSS: createDirectory(projectPath)
    FSS->>PFS: createDirectory(projectPath)
    PFS->>PFS: use selectedStrategy
    PFS-->>FSS: success
    FSS-->>App: success

    %% Git fetch via git binary
    Loop->>Git: fetch()
    Git->>Shell: fetch(remote: origin)
    Shell->>Process: launch(gitURL, ["fetch", origin], env: [GIT_SSL_CAINFO])
    Process-->>Shell: stdout, stderr, exitCode
    Shell-->>Git: GitFetchResult
    Git-->>Loop: ToolResult

    %% Permission evaluation single gate
    Loop->>PE: evaluate(toolCall: edit_file, context:)
    PE->>PE: Step 1 denyRule
    PE->>PE: Step 2 askRule
    PE->>TR: getTool(name:) + needsPermission
    TR-->>PE: destructive=true
    PE->>PMS: isInPlanMode()
    PMS-->>PE: true
    PE->>PE: Step 3 safetyCheck: plan+write -> deny
    PE-->>Loop: Decision(effect: .deny)

    %% SubAgent isolation
    Loop->>AT: execute "agent" tool
    AT->>AT: new FileSystemService(rootPath)
    AT->>AT: new PermissionEngine
    AT->>Sub: AgentLoop(context: subAgentContext)
    Sub->>Sub: run(taskDescription)
    Sub->>Sub: auto-confirm .askConfirmation
    Sub-->>AT: event stream (final text only)
    AT-->>Loop: ToolResult.success

    %% Memory extraction via stopHooks
    Loop->>Loop: query loop ends, no tool_call
    Loop->>ME: extractAndStore(session:...)
    ME->>ME: check if main agent wrote memory
    alt main agent wrote memory
        ME->>ME: skip
    else no memory writes
        ME->>Sub: runForkedAgent(extractPrompt)
        Sub-->>ME: [ExtractedMemory]
        ME->>MS: appendMemory(...)
        MS->>PFS: createDirectory + writeFile
        PFS-->>MS: success
    end
    ME-->>Loop: done
